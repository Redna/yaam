{
  "name": "pi-yaam",
  "version": "1.0.0",
  "description": "Hybrid Semantic-Episodic Agent Memory Engine using a standalone Rust daemon, JSONL persistence, and a web-based Cytoscape visualizer.",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "skills": [
      "./skills/yaam-memory-manager"
    ]
  },
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "setup:yes": "bash scripts/setup.sh --yes",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.9",
    "tsx": "^4.15.7",
    "typebox": "^1.1.38",
    "typescript": "^5.5.2"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0 || ^0.75.0 || ^0.78.0 || ^0.79.0"
  }
}
