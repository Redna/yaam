{
  "name": "yaam-memory",
  "version": "1.0.0",
  "description": "Yet Another Agent Memory plugin for managing task workspaces and tracking structural changes.",
  "mcpServers": {
    "yaam_memory": {
      "command": "python3",
      "args": ["server.py"]
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "type": "command",
        "command": "python3 reconciler.py",
        "timeout": 30
      }
    ]
  }
}
